{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Word2MD - Interactive",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/word2md/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/word2md",
            "args": ["-o", "debug_output"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/word2md"
            },
            "justMyCode": true,
            "stopOnEntry": false,
            "presentation": {
                "hidden": false,
                "group": "Word2MD",
                "order": 1
            }
        },
